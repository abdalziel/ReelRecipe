# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: leave as SQLite default
# Railway: set to the PostgreSQL URL Railway provides (starts with postgresql://)
DATABASE_URL=sqlite:///./recipereel.db

# ── File Storage ──────────────────────────────────────────────────────────────
# Local dev: relative path works fine
# Railway: set to the mounted volume path e.g. /mnt/uploads
UPLOAD_DIR=./uploads

# ── AI Models ─────────────────────────────────────────────────────────────────
# tiny uses ~150MB RAM (recommended for Railway free tier)
# small uses ~500MB RAM (recommended for production/Oracle)
WHISPER_MODEL=tiny

# ── Public Library (GitHub) ───────────────────────────────────────────────────
GITHUB_TOKEN=your_github_pat_here
GITHUB_PUBLIC_REPO=abdalziel/ReelRecipe-Public

# ── Cloudflare R2 Storage (optional — leave blank to use local filesystem) ────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
